/* pages/login/login.wxss */
.login-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 50rpx 0;
  min-height: 100vh;
}
.logo { font-size: 140rpx; margin-bottom: 30rpx; }
.title { font-size: 52rpx; font-weight: bold; color: #222; }
.subtitle { font-size: 26rpx; color: #999; margin-top: 16rpx; }

.form { width: 100%; margin-top: 80rpx; }
.phone-input {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 34rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #eee;
}
.tip {
  font-size: 24rpx;
  color: #bbb;
  text-align: center;
  margin-top: 10rpx;
}

.offline-tip {
  margin-top: 60rpx;
  padding: 24rpx;
  background: #fffbe8;
  border-radius: 12rpx;
  text-align: center;
}
.offline-tip text {
  display: block;
  font-size: 24rpx;
  color: #ff9800;
}
.offline-detail {
  font-size: 22rpx !important;
  color: #999 !important;
  margin-top: 8rpx;
}
