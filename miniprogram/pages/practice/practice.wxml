<!--pages/practice/practice.wxml - 答题练习（单选/判断/多选）-->
<view class="practice-page" wx:if="{{question}}">
  <!-- 顶部进度 -->
  <view class="progress-bar">
    <view class="progress-text">{{currentIndex + 1}} / {{total}}</view>
    <view class="progress-track">
      <view class="progress-fill" style="width: {{(currentIndex + 1) / total * 100}}%"></view>
    </view>
  </view>

  <!-- 题目区 -->
  <view class="question-card card">
    <view class="q-header">
      <text class="type-tag {{question.type}}">{{question.type === 'judge' ? '判断题' : question.type === 'multi' ? '多选题' : '单选题'}}</text>
      <text class="q-tip" wx:if="{{isMulti}}">可多选</text>
    </view>
    <view class="q-title">{{question.title}}</view>

    <!-- 选项 -->
    <view class="options">
      <view
        class="option {{optionStates[index]}}"
        wx:for="{{question.options}}"
        wx:key="index"
        data-index="{{index}}"
        bindtap="onTapOption"
      >
        <text class="opt-label">{{['A','B','C','D','E'][index]}}</text>
        <text class="opt-text">{{item}}</text>
        <text class="opt-icon" wx:if="{{optionStates[index] === 'correct'}}">✓</text>
        <text class="opt-icon wrong-icon" wx:if="{{optionStates[index] === 'wrong'}}">✗</text>
      </view>
    </view>

    <!-- 多选确认按钮 -->
    <button class="confirm-btn" wx:if="{{isMulti && !answered}}" bindtap="onConfirmMulti">
      确认作答
    </button>

    <!-- 解析 -->
    <view class="analysis" wx:if="{{showAnalysis}}">
      <view class="analysis-title">💡 解析</view>
      <view class="analysis-text">{{question.analysis || '正确答案：' + answerText}}</view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar">
    <button class="nav-btn {{currentIndex === 0 ? 'disabled' : ''}}" bindtap="onPrev" disabled="{{currentIndex === 0}}">上一题</button>
    <button class="nav-btn primary" bindtap="onNext">
      {{currentIndex === total - 1 ? '提交' : '下一题'}}
    </button>
  </view>
</view>
