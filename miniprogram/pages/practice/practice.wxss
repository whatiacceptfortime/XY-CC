/* pages/practice/practice.wxss - 答题练习样式 */
.practice-page { padding-bottom: 140rpx; }

/* 进度条 */
.progress-bar {
  padding: 24rpx 30rpx;
  background: #fff;
}
.progress-text {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 14rpx;
}
.progress-track {
  height: 10rpx;
  background: #eee;
  border-radius: 5rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1989fa, #07c160);
  border-radius: 5rpx;
  transition: width 0.3s;
}

/* 题目卡片 */
.question-card { margin-top: 20rpx; }
.q-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.type-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
.type-tag.single { color: #1989fa; background: #e8f3ff; }
.type-tag.judge { color: #ff9800; background: #fff3e0; }
.type-tag.multi { color: #722ed1; background: #f9f0ff; }
.q-tip { font-size: 22rpx; color: #999; }
.q-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.7;
  color: #222;
  margin-bottom: 30rpx;
}

/* 选项 */
.options { margin-top: 10rpx; }
.option {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  background: #f8f9fa;
  border-radius: 14rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.option.chosen {
  background: #e8f3ff;
  border-color: #1989fa;
}
.option.correct {
  background: #e8f8ee;
  border-color: #07c160;
}
.option.wrong {
  background: #fdeaea;
  border-color: #ee0a24;
}
.opt-label {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  background: #fff;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 20rpx;
  color: #666;
  flex-shrink: 0;
}
.option.chosen .opt-label { background: #1989fa; color: #fff; }
.option.correct .opt-label { background: #07c160; color: #fff; }
.option.wrong .opt-label { background: #ee0a24; color: #fff; }
.opt-text { flex: 1; font-size: 30rpx; }
.opt-icon { color: #07c160; font-size: 36rpx; font-weight: bold; }
.opt-icon.wrong-icon { color: #ee0a24; }

/* 多选确认按钮 */
.confirm-btn {
  margin: 30rpx 0 10rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #722ed1, #1989fa);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
}

/* 解析 */
.analysis {
  margin-top: 30rpx;
  padding: 24rpx;
  background: #fffbe8;
  border-radius: 14rpx;
  border-left: 6rpx solid #ffb800;
}
.analysis-title { font-size: 28rpx; font-weight: 600; margin-bottom: 10rpx; }
.analysis-text { font-size: 26rpx; color: #666; line-height: 1.7; }

/* 底部 */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  padding: 16rpx 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.nav-btn {
  flex: 1;
  margin: 0 10rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
  background: #f0f0f0;
  color: #666;
}
.nav-btn.primary { background: #1989fa; color: #fff; }
.nav-btn.disabled { opacity: 0.5; }
