/* pages/admin/question-edit/question-edit.wxss */
.edit-page { padding: 24rpx; min-height: 100vh; background: #f5f6f8; }
.form-card { background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 30rpx; }

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.form-label { font-size: 30rpx; font-weight: 600; color: #333; }
.form-picker {
  font-size: 28rpx;
  color: #1989fa;
  padding: 10rpx 24rpx;
  background: #f0f7ff;
  border-radius: 8rpx;
}

.form-block { padding: 24rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.form-block:last-child { border-bottom: none; }
.form-textarea {
  width: 100%;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
  min-height: 100rpx;
}

.option-row {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}
.opt-letter {
  width: 50rpx; height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  background: #f0f2f5;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.opt-input {
  flex: 1;
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.answer-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 16rpx;
}
.answer-btn {
  width: 70rpx; height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  border-radius: 50%;
  background: #f0f2f5;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
}
.answer-btn.active {
  background: #07c160;
  color: #fff;
}
.answer-tip { font-size: 24rpx; color: #999; margin-top: 12rpx; }
