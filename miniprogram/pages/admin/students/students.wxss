/* pages/admin/students/students.wxss */
.students-page { background: #f5f6f8; min-height: 100vh; padding-bottom: 120rpx; }

.filter-bar { padding: 20rpx; background: #fff; position: sticky; top: 0; z-index: 10; display: flex; gap: 16rpx; align-items: center; }
.filter-search { flex: 1; }
.search-input {
  background: #f0f2f5;
  border-radius: 8rpx;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
}
.import-btn {
  font-size: 24rpx;
  color: #1989fa;
  padding: 12rpx 24rpx;
  background: #e8f3ff;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
.total-bar { padding: 20rpx 30rpx; font-size: 26rpx; color: #888; }

.student-list { padding: 0 24rpx; }
.student-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
}
.stu-avatar {
  width: 88rpx; height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: #fff;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.stu-avatar.expired { background: #ccc; }
.stu-info { flex: 1; }
.stu-name { font-size: 30rpx; font-weight: 600; color: #222; display: flex; align-items: center; gap: 12rpx; }
.stu-status { font-size: 20rpx; padding: 2rpx 12rpx; border-radius: 6rpx; }
.stu-status.active { color: #07c160; background: #e8f8ee; }
.stu-status.expired { color: #ee0a24; background: #fdeaea; }
.stu-meta { font-size: 24rpx; color: #888; margin-top: 6rpx; }
.stu-time { font-size: 22rpx; color: #bbb; margin-top: 4rpx; }
.stu-arrow { font-size: 24rpx; color: #ccc; flex-shrink: 0; }

.empty { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-tip { font-size: 24rpx; color: #bbb; margin-top: 12rpx; }
.loading { text-align: center; padding: 30rpx; color: #999; font-size: 24rpx; }
.fab {
  position: fixed; right: 40rpx; bottom: 120rpx;
  width: 100rpx; height: 100rpx; line-height: 100rpx;
  text-align: center; background: #1989fa; color: #fff;
  font-size: 56rpx; border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(25,137,250,0.4); z-index: 100;
}
