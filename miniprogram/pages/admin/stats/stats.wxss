/* pages/admin/stats/stats.wxss */
.stats-page { padding: 24rpx; background: #f5f6f8; min-height: 100vh; }

/* 核心指标 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.stat-card {
  flex: 1;
  min-width: 44%;
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx 20rpx;
  text-align: center;
}
.stat-num { font-size: 48rpx; font-weight: bold; color: #1989fa; display: block; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* 图表卡片 */
.chart-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}
.chart-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; color: #222; }

/* 柱状图 */
.bar-list { display: flex; flex-direction: column; gap: 20rpx; }
.bar-item { display: flex; align-items: center; }
.bar-label { width: 140rpx; font-size: 26rpx; color: #555; flex-shrink: 0; }
.bar-track {
  flex: 1;
  height: 24rpx;
  background: #f0f2f5;
  border-radius: 12rpx;
  overflow: hidden;
  margin: 0 16rpx;
}
.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #1989fa, #07c160);
  border-radius: 12rpx;
  transition: width 0.5s;
  min-width: 4rpx;
}
.bar-num { width: 60rpx; text-align: right; font-size: 26rpx; font-weight: 600; color: #333; }

/* 题型分布 */
.type-list { display: flex; flex-direction: column; gap: 24rpx; }
.type-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.type-dot { width: 20rpx; height: 20rpx; border-radius: 50%; }
.type-name { font-size: 28rpx; color: #333; width: 120rpx; }
.type-count { font-size: 28rpx; color: #555; flex: 1; }
.type-pct { font-size: 24rpx; color: #999; }

.empty { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.loading { text-align: center; padding: 30rpx; color: #999; font-size: 24rpx; }
