/* pages/admin/questions/questions.wxss */
.questions-page { padding: 0 0 120rpx; background: #f5f6f8; min-height: 100vh; }

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: #fff;
  position: sticky; top: 0; z-index: 10;
}
.filter-item {
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  background: #f0f2f5;
  border-radius: 8rpx;
  white-space: nowrap;
  color: #555;
}
.filter-search { flex: 1; }
.search-input {
  background: #f0f2f5;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  height: 48rpx;
}

/* 题目列表 */
.q-list { padding: 20rpx; }
.q-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}
.q-item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.q-type-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.q-type-tag.single { color: #1989fa; background: #e8f3ff; }
.q-type-tag.judge { color: #ff9800; background: #fff3e0; }
.q-type-tag.multi { color: #722ed1; background: #f9f0ff; }
.q-category { font-size: 22rpx; color: #999; }

.q-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.6;
  color: #222;
  margin-bottom: 16rpx;
}
.q-options {
  display: flex;
  align-items: flex-start;
  padding: 6rpx 0;
}
.opt-letter {
  width: 40rpx; height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 22rpx;
  color: #888;
  flex-shrink: 0;
}
.opt-text { font-size: 26rpx; color: #666; flex: 1; }

.q-item-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
  padding-top: 16rpx;
}
.action-btn { font-size: 26rpx; padding: 8rpx 24rpx; border-radius: 8rpx; }
.action-btn.edit { color: #1989fa; background: #e8f3ff; }
.action-btn.delete { color: #ee0a24; background: #fdeaea; }

/* 空状态/加载 */
.empty { text-align: center; padding: 120rpx 0; color: #999; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.loading { text-align: center; padding: 30rpx; color: #999; font-size: 24rpx; }

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx; bottom: 120rpx;
  width: 100rpx; height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: #1989fa;
  color: #fff;
  font-size: 56rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(25,137,250,0.4);
  z-index: 100;
}
