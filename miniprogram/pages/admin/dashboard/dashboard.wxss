/* pages/admin/dashboard/dashboard.wxss */
.dashboard { padding: 24rpx; min-height: 100vh; background: #f5f6f8; }

/* 概览 */
.overview {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 30rpx;
}
.overview-title { color: rgba(255,255,255,0.7); font-size: 28rpx; margin-bottom: 24rpx; }
.overview-grid {
  display: flex;
  justify-content: space-between;
}
.ov-item { display: flex; flex-direction: column; align-items: center; flex: 1; }
.ov-num { font-size: 48rpx; font-weight: bold; color: #fff; }
.ov-label { font-size: 22rpx; color: rgba(255,255,255,0.6); margin-top: 8rpx; }

/* 菜单 */
.menu-list { background: #fff; border-radius: 20rpx; overflow: hidden; }
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon {
  font-size: 44rpx;
  width: 80rpx; height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f5f6f8;
  border-radius: 16rpx;
  margin-right: 24rpx;
}
.menu-info { flex: 1; }
.menu-name { font-size: 32rpx; font-weight: 600; color: #222; }
.menu-desc { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.menu-arrow { font-size: 40rpx; color: #ccc; }
