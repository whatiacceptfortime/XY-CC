/* pages/admin/student-import/student-import.wxss */
.import-page { padding: 24rpx; min-height: 100vh; background: #f5f6f8; }
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

/* 说明 */
.tips-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.tips-item { font-size: 26rpx; color: #666; padding: 6rpx 0; }
.tips-example {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}

/* 有效期 */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.form-label { font-size: 30rpx; font-weight: 600; }
.form-picker {
  font-size: 28rpx;
  color: #1989fa;
  padding: 10rpx 24rpx;
  background: #f0f7ff;
  border-radius: 8rpx;
}

/* 文本框 */
.text-area-wrap { padding: 20rpx; }
.text-area {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.8;
}

/* 结果 */
.result-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }
.result-row { display: flex; gap: 30rpx; }
.result-success { font-size: 28rpx; color: #07c160; }
.result-fail { font-size: 28rpx; color: #ee0a24; }
.result-errors { margin-top: 16rpx; }
.error-item { font-size: 24rpx; color: #ee0a24; padding: 4rpx 0; }

/* 按钮 */
.actions { padding: 20rpx 0; }
.btn-primary {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: #fff;
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  margin: 16rpx 0;
}
.btn-secondary {
  background: #f0f2f5;
  color: #666;
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  margin: 16rpx 0;
}
