/* pages/profile/profile.wxss */
.profile-page { padding-bottom: 40rpx; }

.user-header {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 0 0 32rpx 32rpx;
}
.avatar {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
}
.default-avatar {
  background: rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 60rpx;
}
.nickname { color: #fff; font-size: 32rpx; margin-top: 20rpx; }
.login-entry { display: flex; flex-direction: column; align-items: center; }

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  margin-top: -30rpx;
  position: relative;
  z-index: 2;
}
.stat-item { display: flex; flex-direction: column; align-items: center; }
.s-num { font-size: 44rpx; font-weight: bold; color: #333; }
.s-label { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* 菜单 */
.menu-list { margin-top: 20rpx; padding: 0; }
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 40rpx; margin-right: 24rpx; }
.menu-name { flex: 1; font-size: 30rpx; color: #333; }
.menu-arrow { font-size: 40rpx; color: #ccc; }
