<!--pages/profile/profile.wxml-->
<view class="profile-page">
  <!-- 用户信息 -->
  <view class="user-header theme-bg">
    <block wx:if="{{hasLogin}}">
      <view class="avatar default-avatar">{{userInfo.nickName ? userInfo.nickName.charAt(0) : '👤'}}</view>
      <view class="nickname" bindlongpress="onTitleLongPress">{{userInfo.nickName || '已登录'}}</view>
    </block>
    <view wx:else class="login-entry" bindtap="onLogin">
      <view class="avatar default-avatar">👤</view>
      <view class="nickname" bindlongpress="onTitleLongPress">点击登录</view>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-card card">
    <view class="stat-item">
      <text class="s-num">{{stats.totalAnswered}}</text>
      <text class="s-label">已答题数</text>
    </view>
    <view class="stat-item">
      <text class="s-num theme-color">{{stats.accuracy}}</text>
      <text class="s-label">正确率</text>
    </view>
    <view class="stat-item">
      <text class="s-num">{{stats.dayStreak}}</text>
      <text class="s-label">连续打卡</text>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-list card">
    <view
      class="menu-item"
      wx:for="{{menus}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onMenuTap"
    >
      <text class="menu-icon">{{item.icon}}</text>
      <text class="menu-name">{{item.name}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
