/* pages/index/index.wxss */
.container { padding-bottom: 40rpx; }

/* Banner */
.banner {
  padding: 50rpx 40rpx 40rpx;
  color: #fff;
  border-radius: 0 0 32rpx 32rpx;
}
.banner-title { font-size: 40rpx; font-weight: bold; }
.banner-desc { font-size: 26rpx; opacity: 0.9; margin-top: 12rpx; }
.banner-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 40rpx;
}
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-num { font-size: 44rpx; font-weight: bold; }
.stat-label { font-size: 24rpx; opacity: 0.85; margin-top: 6rpx; }

/* 公告 */
.notice { display: flex; align-items: center; }
.notice-tag {
  background: #fff3e0;
  color: #ff9800;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.notice-text { font-size: 26rpx; color: #666; }

/* 考试入口 */
.exam-entry {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1a1a2e, #16213e) !important;
  margin-bottom: 20rpx;
}
.exam-icon { font-size: 52rpx; margin-right: 24rpx; }
.exam-info { flex: 1; }
.exam-title { font-size: 34rpx; font-weight: bold; color: #fff; }
.exam-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); margin-top: 6rpx; }
.exam-arrow { font-size: 26rpx; color: #1989fa; white-space: nowrap; }

/* 科目列表 */
.category-list { margin-top: 10rpx; }
.category-item {
  display: flex;
  align-items: center;
}
.cat-icon {
  font-size: 52rpx;
  width: 90rpx;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  background: #f0f7ff;
  border-radius: 20rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.cat-info { flex: 1; }
.cat-name { font-size: 32rpx; font-weight: 600; color: #222; }
.cat-desc { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.cat-arrow { font-size: 44rpx; color: #ccc; }
