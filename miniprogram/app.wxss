/* app.wxss - 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 主题色 */
.theme-bg { background-color: #1989fa; }
.theme-color { color: #1989fa; }

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: #fff;
  border-radius: 48rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  margin: 30rpx 40rpx;
}
.btn-primary:active { opacity: 0.85; }

/* 标题 */
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  margin: 30rpx 20rpx 10rpx;
  color: #222;
}

/* 空状态 */
.empty {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
  font-size: 26rpx;
}
