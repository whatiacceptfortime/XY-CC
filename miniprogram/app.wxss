/* app.wxss - 全局样式（统一规范） */
page {
  background-color: #f5f6f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}

/* 主题色 */
.theme-bg { background-color: #1989fa; }
.theme-color { color: #1989fa; }

/* 卡片 - 统一圆角16rpx */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

/* 主按钮 - 统一88rpx高/44rpx圆角 */
.btn-primary {
  background: linear-gradient(135deg, #1989fa, #07c160);
  color: #fff;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  text-align: center;
  margin: 30rpx 40rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.btn-primary:active { opacity: 0.85; }

/* 次按钮 */
.btn-secondary {
  background: #f0f2f5;
  color: #666;
  border-radius: 44rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  text-align: center;
  margin: 16rpx 40rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* 题型标签 - 统一样式 */
.type-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.type-tag.single { color: #1989fa; background: #e8f3ff; }
.type-tag.judge { color: #ff9800; background: #fff3e0; }
.type-tag.multi { color: #722ed1; background: #f9f0ff; }

/* 选项标签 - 统一52rpx圆形 */
.opt-label {
  width: 52rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  background: #fff;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 20rpx;
  color: #666;
  flex-shrink: 0;
}

/* 选项文字 - 防溢出 */
.opt-text {
  flex: 1;
  min-width: 0;
  word-break: break-all;
  font-size: 30rpx;
}

/* 标题 */
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  margin: 30rpx 20rpx 10rpx;
  color: #222;
}

/* 空状态 */
.empty {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
  font-size: 26rpx;
}

/* 文字截断工具类 */
.text-ellipsis {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.text-ellipsis-1 {
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
